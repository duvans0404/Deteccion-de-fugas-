PORT=3000
NODE_ENV=development
DB_SYNC_ALTER=false
SERVE_FRONTEND=false

JWT_SECRET=replace_with_a_long_random_secret
INGEST_API_KEY=replace_with_a_long_random_device_key
FRONTEND_ORIGIN=http://localhost:8000,http://127.0.0.1:8000
DATABASE_URL=

# Local primero: usa tu backend en development, frontend estatico en :8000
# y la misma INGEST_API_KEY en simulacion/modulos/config.cpp.
# Si quieres probar local apuntando a Railway, puedes usar DATABASE_URL o sustituir los DB_*.
DB_HOST=localhost
DB_PORT=3306
DB_USER=iot_user
DB_PASS=change_this_password
DB_NAME=iot_water

# Railway:
# NODE_ENV=production
# DB_SYNC_ALTER=false
# FRONTEND_ORIGIN=https://tu-frontend.railway.app
# DATABASE_URL=mysql://usuario:password@host:puerto/base
